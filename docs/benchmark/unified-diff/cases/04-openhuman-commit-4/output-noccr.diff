         let id = read_required::<String>(&params, "id")?;
         let enabled = params
             .get("enabled")
             .and_then(Value::as_bool)
             .ok_or_else(|| "missing required param 'enabled'".to_string())?;
         to_json(ops::flows_set_enabled(&config, id.trim(), enabled).await?)
