         return Vec::new();
     };
     let Some(kind_value) = trigger.config.get("trigger_kind") else {
         return Vec::new();
     };
     let kind: TriggerKind = match serde_json::from_value(kind_value.clone()) {
         Ok(k) => k,
         Err(_) => return Vec::new(),
     };
