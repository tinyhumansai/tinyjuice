@@ -135,156 +135,158 @@ cef = { version = "=146.4.1", default-features = false }
 openhuman_core = { path = "../..", package = "openhuman", default-features = false }
 tinyjuice = { version = "0.1", default-features = false }
 
 [target.'cfg(unix)'.dependencies]
